10 REM 6502 LED LIGHT SHOW - TANG NANO 9K
15 REM PRESIONA 'C' EN CUALQUIER MOMENTO PARA SALIR
20 LET M = 192
30 GOTO 100

100 REM PATRON 1: CHASE (IZQUIERDA A DERECHA)
110 LET P = 1
120 FOR I = 0 TO 5
130 LET V = M + 63 - P
140 LEDS V
150 WAIT 80
160 GET K : IF K=67 THEN QUIT
170 LET P = P * 2
180 NEXT I
190 GOTO 200

200 REM PATRON 2: KNIGHT RIDER (REBOTE)
210 LET P = 1
220 FOR I = 0 TO 5
230 LET V = M + 63 - P
240 LEDS V
250 WAIT 80
260 GET K : IF K=67 THEN QUIT
270 LET P = P * 2
280 NEXT I
290 LET P = 16
300 LET V = M + 63 - P
310 LEDS V
320 WAIT 80
330 GET K : IF K=67 THEN QUIT
340 LET P = P / 2
350 IF P > 0 THEN 300
360 GOTO 300

300 REM PATRON 3: CONTEO BINARIO (0-63)
310 FOR C = 0 TO 63
320 LET V = M + 63 - C
330 LEDS V
340 WAIT 50
350 GET K : IF K=67 THEN QUIT
360 NEXT C
370 GOTO 400

400 REM PATRON 4: PARPADEO Y ALTERNADO
410 FOR I = 0 TO 4
420 LEDS 192
430 WAIT 100
440 GET K : IF K=67 THEN QUIT
450 LEDS 255
460 WAIT 100
470 GET K : IF K=67 THEN QUIT
480 NEXT I
490 LEDS 170
500 WAIT 200
510 GET K : IF K=67 THEN QUIT
520 LEDS 85
530 WAIT 200
540 GET K : IF K=67 THEN QUIT
550 GOTO 100