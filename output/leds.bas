10 REM LED LIGHT SHOW CON GOSUB
15 REM PRESIONA 'C' PARA DETENER
20 LET M = 192
30 GOSUB 1000
40 GOTO 100
100 REM BUCLE PRINCIPAL DE PATRONES
110 GOSUB 200
120 GOSUB 400
130 GOSUB 600
140 GOSUB 800
150 GOTO 100
200 REM PATRON 1: CHASE (IZQ A DER)
210 LET P = 1
220 FOR I = 0 TO 5
230 GOSUB 900
240 LET P = P * 2
250 NEXT I
260 RETURN
400 REM PATRON 2: KNIGHT RIDER (REBOTE)
410 LET P = 1
420 FOR I = 0 TO 5
430 GOSUB 900
440 LET P = P * 2
450 NEXT I
460 LET P = 16
470 FOR I = 0 TO 4
480 GOSUB 900
490 LET P = P / 2
500 NEXT I
510 RETURN
600 REM PATRON 3: CONTEO BINARIO (0-63)
610 FOR C = 0 TO 63
620 LET V = M + 63 - C
630 LEDS V
640 WAIT 50
650 GET K : IF K=67 THEN STOP
660 NEXT C
670 RETURN
800 REM PATRON 4: PARPADEO Y ALTERNADO
810 FOR I = 0 TO 4
820 LEDS 192 : WAIT 100
830 GET K : IF K=67 THEN STOP
840 LEDS 255 : WAIT 100
850 GET K : IF K=67 THEN STOP
860 NEXT I
870 RETURN
900 REM SUBRUTINA COMUN: ACTUALIZAR LED + DELAY + TECLA
910 LET V = M + 63 - P
920 LEDS V
930 WAIT 80
940 GET K : IF K=67 THEN STOP
950 RETURN
1000 REM SUBRUTINA DE INICIALIZACION
1010 PRINT "INICIANDO SHOW..."
1020 RETURN