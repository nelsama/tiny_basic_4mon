10 REM 6502 LED LIGHT SHOW - TANG NANO 9K
15 REM PRESIONA 'C' PARA SALIR (ASCII 67)
20 LET M = 192
30 GOTO 100
100 REM PATRON 1: CHASE (IZQ A DER)
110 LET P = 1
120 FOR I = 0 TO 5
130 LET V = M + 63 - P
140 LEDS V
150 WAIT 80
160 GET K : IF K=67 THEN QUIT
170 LET P = P * 2
180 NEXT I
190 GOTO 200
200 REM PATRON 2: KNIGHT RIDER (REBOTE)
210 LET P = 1
220 FOR I = 0 TO 4
230 LET V = M + 63 - P
240 LEDS V
250 WAIT 80
260 GET K : IF K=67 THEN QUIT
270 LET P = P * 2
280 NEXT I
290 LET P = 8
300 FOR I = 0 TO 4
310 LET V = M + 63 - P
320 LEDS V
330 WAIT 80
340 GET K : IF K=67 THEN QUIT
350 LET P = P / 2
360 NEXT I
370 GOTO 400
400 REM PATRON 3: CONTEO BINARIO (0-63)
410 FOR C = 0 TO 63
420 LET V = M + 63 - C
430 LEDS V
440 WAIT 50
450 GET K : IF K=67 THEN QUIT
460 NEXT C
470 GOTO 500
500 REM PATRON 4: PARPADEO Y ALTERNADO
510 FOR I = 0 TO 4
520 LEDS 192 : WAIT 100
530 GET K : IF K=67 THEN QUIT
540 LEDS 255 : WAIT 100
550 GET K : IF K=67 THEN QUIT
560 NEXT I
570 LEDS 170 : WAIT 200
580 GET K : IF K=67 THEN QUIT
590 LEDS 85 : WAIT 200
600 GET K : IF K=67 THEN QUIT
610 GOTO 100